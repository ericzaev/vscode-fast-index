{
  "name": "vscode-fast-index",
  "displayName": "Fast Project Indexer ",
  "description": "Lightning-fast text search for VS Code using a background inverted trigram index.",
  "publisher": "eric",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ericzaev/vscode-fast-index.git"
  },
  "keywords": [
    "search",
    "fast",
    "index",
    "large project"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "fast-index-explorer",
          "title": "Fast Index",
          "icon": "$(zap)"
        }
      ]
    },
    "views": {
      "fast-index-explorer": [
        {
          "type": "webview",
          "id": "fast-index.sidebar",
          "name": "Fast Index Search"
        }
      ]
    },
    "commands": [
      {
        "command": "vscode-fast-index.buildIndex",
        "title": "Fast Index: Build Project Index"
      }
    ],
    "configuration": {
      "title": "Fast Indexer",
      "properties": {
        "fastIndex.includeExtensions": {
          "type": "string",
          "default": "",
          "description": "Comma-separated list of file extensions to index (e.g., ts,js,md). Leave empty to index all extensions."
        },
        "fastIndex.excludePatterns": {
          "type": "string",
          "default": "{**/node_modules/**,**/.git/**,**/dist/**,**/out/**,**/*.png,**/*.jpg,**/*.svg}",
          "description": "File and folder patterns to ignore during indexing (Glob format)."
        },
        "fastIndex.maxFileSizeKB": {
          "type": "number",
          "default": 512,
          "description": "Maximum file size in kilobytes to index. Files larger than this will be skipped."
        },
        "fastIndex.maxResults": {
          "type": "number",
          "default": 50,
          "description": "Maximum number of search results to display."
        },
        "fastIndex.debounceDelay": {
          "type": "number",
          "default": 250,
          "description": "Input delay (in milliseconds) before triggering the search."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "npm run compile",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.109.0",
    "typescript": "^5.9.3"
  }
}
